{
  "name": "OgdenBasicEnglish",
  "version": "0.2.0",
  "description": "Ogden Basic English 850 — structured learning corpus and resource index for human study and agent distillation",
  "updated": "2026-06-08",
  "core_concept": {
    "vocabulary_size": 850,
    "operator_verbs": 18,
    "classes": ["operations(100)", "things_general(400)", "things_picturable(200)", "qualities_general(100)", "qualities_opposites(50)"],
    "claim": "850 words + operators + affixes + compounds cover ~90% of everyday concepts",
    "multipliers": ["operator+direction (phrasal verbs)", "operator+noun", "affixes (-S/-ER/-ING/-ED/-LY/UN-)", "compounds"]
  },
  "structure": {
    "00-START-HERE.md": "master overview + 4-week path + core focus points",
    "01-foundations/": "skeleton: 18 operators, directions/prepositions, grammar rules",
    "02-vocabulary/": "850 words in priority tiers + lists + pdf",
    "03-composition/": "phrasal verbs, affixes, compounds (the multiplier)",
    "04-practice/": "picture->sentence, reading list, ETP pdf",
    "05-distill/": "JSONL schema + prompt targets for agents",
    "reference/": "1937 pamphlet, Chinese survey, copyright, raw HTML mirrors"
  },
  "local_files": {
    "foundations": [
      "01-foundations/operators-18.md",
      "01-foundations/directions-prepositions.md",
      "01-foundations/grammar-rules.md"
    ],
    "vocabulary": [
      {"path": "02-vocabulary/tier-guide.md", "desc": "learning-priority tiers"},
      {"path": "02-vocabulary/words-ogden-order.md", "desc": "authoritative 850 taxonomy"},
      {"path": "02-vocabulary/basic-english-850.txt", "desc": "flat flashcard list"},
      {"path": "02-vocabulary/ogdens-basic-english-850.pdf", "desc": "printable word list"}
    ],
    "composition": [
      "03-composition/phrasal-verbs.md",
      "03-composition/derivation-affixes.md",
      "03-composition/compounds.md"
    ],
    "practice": [
      {"path": "04-practice/reading-list.md", "desc": "constrained-input reading"},
      {"path": "04-practice/english-through-pictures-book1.pdf", "desc": "Richards ETP Book 1; verify Archive terms before redistribution"}
    ],
    "distill": ["05-distill/schema.md"],
    "reference": [
      {"path": "reference/begr-1937.md", "desc": "1937 pamphlet index (verified sections)"},
      {"path": "reference/begr-1937.html", "desc": "full text, no-copyright pamphlet"},
      {"path": "reference/survey-zh.md", "desc": "Chinese resource survey 2026-06-08"},
      {"path": "reference/copyright.md", "desc": "redistribution notes"},
      {"path": "reference/mirrors/", "desc": "raw HTML snapshots from zbenglish.net"}
    ]
  },
  "remote_only": [
    {"title": "ZbEnglish mirror (primary hub)", "url": "https://zbenglish.net/sites/basic/basiceng.html", "status": "active"},
    {"title": "Wiktionary 850-word appendix", "url": "https://en.wiktionary.org/wiki/Appendix:Basic_English_word_list", "status": "active"},
    {"title": "Learning Basic English (1945)", "url": "https://archive.org/details/in.ernet.dli.2015.166025", "status": "borrow"},
    {"title": "Basic English: General Introduction (1930)", "url": "https://onlinebooks.library.upenn.edu/webbin/book/lookupid?key=ha102944655", "status": "preview_or_borrow"},
    {"title": "The ABC of Basic English (1932)", "url": "https://books.google.com/books?id=Q-AtAAAAYAAJ", "status": "preview"},
    {"title": "850 words Chinese?? (??)", "url": "https://www.jianshu.com/p/eec638be62f6", "status": "active"},
    {"title": "Bible in Basic English", "url": "https://archive.org/details/BBEFreePDFBibleinBasicEnglish", "status": "active_public_domain"}
  ],
  "dead_links": ["http://ogden.basic-english.org/", "https://basic-english.org/"],
  "agent_usage": {
    "read_order": ["AGENTS.md", "manifest.json", "00-START-HERE.md", "01-foundations/operators-18.md", "01-foundations/grammar-rules.md", "02-vocabulary/words-ogden-order.md", "03-composition/phrasal-verbs.md"],
